# mlx-lora-finetuner backend configuration.
# Copy to backend/.env and uncomment what you want to override.
# All settings are env vars with the MLXLF_ prefix (see app/config.py).

# Root of all persisted state: models/, datasets/, runs/, exports/, cache/, app.db.
# MLXLF_DATA_DIR=~/.mlx-lora-finetuner

# Backend bind host.
# MLXLF_HOST=127.0.0.1

# Backend port.
# MLXLF_PORT=8000

# Hugging Face token for gated/private models and higher rate limits (unset by default).
# MLXLF_HF_TOKEN=

# Path to a llama.cpp checkout containing convert_hf_to_gguf.py, needed for GGUF
# export (unset by default; falls back to <data_dir>/cache/llama.cpp).
# MLXLF_LLAMA_CPP_DIR=

# Built frontend served at / by the production `mlxlf` entry point. Defaults to
# the repo's frontend/dist; if it has no index.html, the app runs API-only.
# MLXLF_STATIC_DIR=

# Note: MLXLF_E2E_DATA_DIR is read only by the e2e scripts (e2e/smoke_*.py),
# not by app/config.py — see README "Testing".
